rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: properties
    // Document ID: propertyId (string)
    // ... (campos definidos: title, location, price, etc.)

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "janiceleroy@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['id', 'title', 'location', 'price', 'currency', 'imageUrl', 'type', 'listingType']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.price is number && data.price >= 0;
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProperty(request.resource.data);
      allow update: if isAdmin() && isValidProperty(request.resource.data);
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
